<Window x:Class="CmdHub.Views.ProcessPerformanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500" Height="370"
        MinWidth="420" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#111111"
        Closing="Window_Closing"
        Title="Process Performance">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Process Performance"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="White"/>
            <Border Background="#2A2A2A" CornerRadius="10" Padding="8,2" Margin="10,0,0,0">
                <TextBlock x:Name="TxtStatusBadge"
                           Text="Stopped"
                           Foreground="#AAAAAA"
                           FontSize="11"
                           FontWeight="SemiBold"/>
            </Border>
        </StackPanel>

        <Border Grid.Row="2" CornerRadius="6" Background="#1B1B1B" BorderBrush="#303030" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Process" Foreground="#8C8C8C" Margin="0,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtProcessName" Foreground="White" Margin="0,4" Text="-"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="PID" Foreground="#8C8C8C" Margin="0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtPid" Foreground="White" Margin="0,4" Text="-"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU Usage" Foreground="#8C8C8C" Margin="0,4"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtCpu" Foreground="#4FC3F7" FontWeight="SemiBold" Margin="0,4" Text="-"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Working Set" Foreground="#8C8C8C" Margin="0,4"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtWorkingSet" Foreground="White" Margin="0,4" Text="-"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Private Memory" Foreground="#8C8C8C" Margin="0,4"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtPrivateMemory" Foreground="White" Margin="0,4" Text="-"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Threads / Handles" Foreground="#8C8C8C" Margin="0,4"/>
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtThreadsHandles" Foreground="White" Margin="0,4" Text="-"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Uptime" Foreground="#8C8C8C" Margin="0,4"/>
                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="TxtUptime" Foreground="White" Margin="0,4" Text="-"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Last Update" Foreground="#8C8C8C" Margin="0,4"/>
                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="TxtUpdated" Foreground="White" Margin="0,4" Text="-"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="4"
                   x:Name="TxtHint"
                   Foreground="#8C8C8C"
                   FontSize="11"
                   Text="Sampling every 1 second. Start the command to view live process metrics."/>
    </Grid>
</Window>
