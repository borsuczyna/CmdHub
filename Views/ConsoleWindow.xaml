<Window x:Class="CmdHub.Views.ConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="800" Height="500"
        MinWidth="480" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Background="#0C0C0C"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <Ellipse x:Name="StatusDot" Width="10" Height="10"
                         Fill="Gray" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStatus"
                           Text="Stopped"
                           Foreground="#858585"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <Button Content="▶ Start"
                        Style="{StaticResource ToolBtn}"
                        x:Name="BtnStart"
                        Margin="2,0"
                        Click="BtnStart_Click"/>
                <Button Content="■ Stop"
                        Style="{StaticResource ToolBtn}"
                        x:Name="BtnStop"
                        Margin="2,0"
                        Click="BtnStop_Click"/>
                <Button Content="↺ Restart"
                        Style="{StaticResource ToolBtn}"
                        x:Name="BtnRestart"
                        Margin="2,0"
                        Click="BtnRestart_Click"/>

                <Separator Width="1" Background="#3C3C3C" Margin="8,4"/>

                <Button Content="Clear"
                        Style="{StaticResource ToolBtn}"
                        Margin="2,0"
                        Click="BtnClear_Click"/>
                <Button Content="Copy All"
                        Style="{StaticResource ToolBtn}"
                        Margin="2,0"
                        Click="BtnCopyAll_Click"/>

                <Button x:Name="BtnTimestamp"
                    Content="Timestamps: Off"
                    Style="{StaticResource ToolBtn}"
                    Margin="8,0,2,0"
                    Click="BtnTimestamp_Click"/>
            </StackPanel>
        </Border>

        <!-- Output Area -->
        <RichTextBox x:Name="OutputBox"
                     Grid.Row="1"
                     Background="#0C0C0C"
                     Foreground="#CCCCCC"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="13"
                     BorderThickness="0"
                     IsReadOnly="True"
                     IsDocumentEnabled="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Padding="8">
            <RichTextBox.Resources>
                <Style TargetType="Paragraph">
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="LineHeight" Value="18"/>
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#007ACC">
            <TextBlock x:Name="TxtStatusBar"
                       Foreground="White"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="8,0"/>
        </Border>
    </Grid>
</Window>
